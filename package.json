{
  "name": "@opendatalabs/darshana",
  "version": "0.0.0",
  "description": "Crawl any web app and generate a labeled PDF, HTML viewer, or image set for design review.",
  "type": "module",
  "bin": {
    "darshana": "./src/index.mjs"
  },
  "files": [
    "src/",
    "examples/",
    "README.md"
  ],
  "dependencies": {
    "playwright": "^1.60.0",
    "pdf-lib": "^1.17.1",
    "path-to-regexp": "^8.0.0"
  },
  "devDependencies": {
    "semantic-release": "^25.0.0",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/release-notes-generator": "^14.0.0",
    "@semantic-release/npm": "^12.0.0",
    "@semantic-release/github": "^10.0.0",
    "conventional-changelog-conventionalcommits": "^8.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false,
    "registry": "https://registry.npmjs.org/",
    "tag": "latest"
  },
  "keywords": ["playwright", "screenshot", "pdf", "html", "design-review", "crawler", "darshana"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vana-com/darshana.git"
  }
}
